# DataDog Configuration
DD_ACCESS_TOKEN=your_datadog_access_token_here

# Services to Monitor (comma-separated)
SERVICES=pythia,bifrost,contextforge,litellm,langfuse

# Regions to Monitor (comma-separated)
REGIONS=uw2p,uw2d,uw2s

# Dashboard Configuration
APP_VERSION=0.0.1
ENVIRONMENT=production

# Optional: Custom time ranges for metrics (in hours)
METRICS_TIME_RANGE=24