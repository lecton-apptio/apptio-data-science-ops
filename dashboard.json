"formula":"rate_limit","alias":"429 Errors"}]}]},"layout":{"x":0,"y":9,"width":12,"height":3}},{"id":3736393809766640,"definition":{"type":"note","content":"**Security Monitoring Setup:**\n\n**Required Instrumentation:**\n1. Log authentication attempts (success/failure)\n2. Track authorization decisions\n3. Monitor sensitive data access\n4. Implement audit logging\n\n**Compliance Requirements:**\n- SOC 2: Access logging, encryption\n- GDPR: Data access audit trails\n- HIPAA: PHI access monitoring (if applicable)\n\n**Recommended Alerts:**\n- Spike in 401/403 errors\n- Unusual access patterns\n- Failed login attempts from new IPs\n- Privilege escalation attempts","background_color":"red","font_size":"14","text_align":"left","show_tick":false,"has_padding":true},"layout":{"x":0,"y":12,"width":12,"height":3}}]},"layout":{"x":0,"y":61,"width":12,"height":16}}],"template_variables":[{"name":"env","prefix":"env","available_values":[],"default":"*"},{"name":"service","prefix":"service","available_values":[],"default":"pythia"}],"layout_type":"ordered","notify_list":[],"pause_auto_refresh":false,"template_variable_presets":[{"name":"Last 30 Days","template_variables":[{"name":"env","value":"*"},{"name":"service","value":"pythia"}]}],"reflow_type":"fixed"}